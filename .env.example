# =============================================================================
# Random Quotes API — environment examples (no secrets committed)
# =============================================================================
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# Local runs load `.env` automatically via `dotenv` when you use:
#   npm start    → server.js
#   npm run build → scripts/prep-quotes.js
#
# Production: `npm run build` downloads quotes from a default GitHub Release URL
# baked into scripts/prep-quotes.js — you do NOT need QUOTES_CSV_URL on Vercel
# unless you want a different file.
#
# See README.md → “Environment variables”.
# =============================================================================

# --- Build-time (optional overrides) -----------------------------------------
# Override the default GitHub Release URL used during `npm run build`.
#
# QUOTES_CSV_URL=https://example.com/other-quotes.csv

# Skip network download and git-less fallback (e.g. local dev with `git lfs pull`).
# Default CSV is still used at runtime via quotes.sample.csv if quotes.csv missing.
#
# SKIP_REMOTE_QUOTES_DOWNLOAD=false

# --- Runtime -----------------------------------------------------------------
# Override which CSV file to load (default: quotes.csv in project root).
# Relative paths are resolved from process.cwd().
#
# QUOTES_CSV_PATH=quotes.csv

# Set to `true` to disable automatic fallback to quotes.sample.csv when the
# primary file is missing, empty, or a Git LFS pointer (strict errors instead).
#
# DISABLE_QUOTES_FALLBACK=false

# Local Express server port (default: 3000).
#
# PORT=3000
